# Node
node_modules/
*.log
npm-debug.log*

# Python (foreign virtualenv kept out per WORKFLOW Q2 / P-08)
.venv/
__pycache__/

# Editor / OS
.DS_Store
*.swp
.vscode/
.idea/

# orchestra per-project state — consumer-side artifacts must never appear
# in the plugin repo. Release-gate prerequisite per PRD §11.2 / §12.
# Parent-dir pattern: the plugin repo has no legitimate runtime artifacts
# under .claude/.orchestra/ (covers local.yaml, metrics/, sessions/,
# DRIFT-REPORT.md, SUMMARY-*.md, and any other generated outputs).
.claude/.orchestra/

# scripts/mcp-servers/ allow-list per PRD §11.3.
# Only the two shipped MCP servers are tracked; everything else under
# scripts/mcp-servers/ is dev-only or accidental and must not be packaged.
scripts/mcp-servers/*
!scripts/mcp-servers/orchestra-fs.js
!scripts/mcp-servers/orchestra-probe.js
