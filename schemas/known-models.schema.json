{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra:known-models",
  "title": "orchestra known-models manifest",
  "description": "Closed list of Anthropic model ids that agent frontmatter may reference. Real ids only — no project-local aliases. See PRD §8.10 / DESIGN-001-infra §2.4.",
  "type": "object",
  "required": ["models"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/model" }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "required": ["id", "tier", "supportsContextMode"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Anthropic model id exactly as accepted by the API (no aliases)."
        },
        "tier": { "enum": ["opus", "sonnet", "haiku"] },
        "default": { "type": "boolean" },
        "supportsContextMode": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["default", "1m"] }
        }
      }
    }
  }
}
